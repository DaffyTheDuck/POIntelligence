# .env.example
# Copy this file to .env and fill in your values.
# Lines starting with # are comments. Never commit .env to git.
#
# Two-machine setup:
#   Windows machine  → runs React frontend + FastAPI backend
#   Linux machine    → runs Ollama, Redis, Celery worker
#
# On the Windows machine, OLLAMA_BASE_URL and REDIS_URL point to the Linux LAN IP.
# On the Linux machine, both point to localhost.

# ===========================================================================
# Application
# ===========================================================================

APP_NAME="PO Intelligence"
APP_VERSION="0.1.0"
DEBUG=false
LOG_LEVEL=INFO

# ===========================================================================
# Ollama — local vision model on the Linux GPU machine
# ===========================================================================

# Windows dev machine: use Linux machine's LAN IP
# OLLAMA_BASE_URL=http://192.168.1.x:11434
# Linux machine (running Ollama locally):
OLLAMA_BASE_URL=http://localhost:11434

OLLAMA_MODEL=phi3.5-vision
OLLAMA_TIMEOUT_SECONDS=60
OLLAMA_MAX_RETRIES=2

# ===========================================================================
# Claude — confidence-based fallback
# ===========================================================================

# Required. Get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

CLAUDE_MODEL=claude-opus-4-5
CLAUDE_TIMEOUT_SECONDS=90
CLAUDE_MAX_TOKENS=4096

# ===========================================================================
# Confidence routing thresholds (architecture decision #3 and #4)
# ===========================================================================

# Fields below this score → escalate to Claude
# 0.0 = always use local only | 1.0 = always use Claude (good for demos)
CONFIDENCE_THRESHOLD=0.75

# |local_score - claude_score| above this → flag for human review
DISAGREEMENT_THRESHOLD=0.15

# ===========================================================================
# Redis — Celery broker and result backend (architecture decision #6)
# ===========================================================================

# Windows dev machine: use Linux machine's LAN IP
# REDIS_URL=redis://192.168.1.x:6379/0
# Linux machine:
REDIS_URL=redis://localhost:6379/0

REDIS_JOB_TTL_SECONDS=86400

# ===========================================================================
# Celery worker (architecture decision #6)
# ===========================================================================

# Keep at 1 — GTX 1650 has 4GB VRAM, two concurrent phi3.5-vision runs = OOM
CELERY_WORKER_CONCURRENCY=1
CELERY_TASK_TIMEOUT_SECONDS=300

# ===========================================================================
# surya OCR (architecture decision #7)
# ===========================================================================

# cuda on Linux GPU machine | cpu on Windows dev machine
SURYA_DEVICE=cuda
SURYA_BATCH_SIZE=1

# Fuzzy match ratio below this falls through to LLM spatial hint (decision #8)
OCR_FUZZY_MATCH_THRESHOLD=0.85

# ===========================================================================
# File upload
# ===========================================================================

UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=20
# Comma-separated list is handled by pydantic-settings automatically for List[str]
ALLOWED_MIME_TYPES=["application/pdf","image/jpeg","image/png","image/tiff","image/webp"]

# ===========================================================================
# IMAP email ingestion — optional, leave blank to disable (decision #1)
# All three must be set together, or all three left blank.
# ===========================================================================

IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USERNAME=your-email@gmail.com
# For Gmail: generate an App Password at myaccount.google.com/apppasswords
IMAP_PASSWORD=your-app-password
IMAP_MAILBOX=INBOX
IMAP_POLL_INTERVAL_SECONDS=60
# Only process emails whose subject contains this string (leave blank for all)
IMAP_ATTACHMENT_SUBJECT_FILTER=Purchase Order

# ===========================================================================
# Export and ERP webhook (architecture decision #9)
# ===========================================================================

EXPORT_DIR=./exports

# Leave blank to disable webhooks (export-only mode)
WEBHOOK_URL=
WEBHOOK_TIMEOUT_SECONDS=10
# Optional HMAC secret — if set, X-Signature header is added to every POST
WEBHOOK_SECRET=
